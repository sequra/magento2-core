<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="3columns"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>
        <referenceContainer name="product.info.main">
            <block class="Sequra\Core\Block\Product"
                   name="sequra.product.widget"
                   template="Sequra_Core::widget/product.phtml"
            />
            <block class="Sequra\Core\Block\Banner"
                   name="sequra.banner.product"
                   template="Sequra_Core::banner.phtml">
                <arguments>
                    <argument name="display_location" xsi:type="string">displayOnProductPage</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
