<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>
        <referenceContainer name="content">
            <block class="Sequra\Core\Block\Cart"
                   name="sequra.cart.widget"
                   template="Sequra_Core::widget/cart.phtml"
           />
        </referenceContainer>
        <referenceContainer name="checkout.cart.totals.container">
            <block class="Sequra\Core\Block\Banner"
                   name="sequra.banner.cart"
                   template="Sequra_Core::banner.phtml">
                <arguments>
                    <argument name="display_location" xsi:type="string">displayOnCartPage</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
