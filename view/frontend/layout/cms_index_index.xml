<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>
        <referenceContainer name="content">
            <block class="Sequra\Core\Block\Banner"
                   name="sequra.banner.home"
                   template="Sequra_Core::banner.phtml"
                   after="cms_page">
                <arguments>
                    <argument name="display_location" xsi:type="string">displayOnHomePage</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
